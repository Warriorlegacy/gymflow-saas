{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2023", "DOM"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "allowJs": false,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@gymflow/lib/*": ["packages/lib/src/*"],
      "@gymflow/services/*": ["packages/services/src/*"],
      "@gymflow/ui/*": ["packages/ui/src/*"]
    }
  }
}

