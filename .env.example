# ===========================================
# GymFlow Environment Variables
# ===========================================
# Copy this file to .env.local and fill in the values

# ===========================================
# REQUIRED: Supabase Configuration
# ===========================================
# Get free keys at https://supabase.com
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ===========================================
# AI Configuration (Free providers)
# ===========================================
# Get free keys at https://console.groq.com
GROQ_API_KEY=your-groq-api-key
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.3-70b-versatile

# Get free key at https://aistudio.google.com
GEMINI_API_KEY=your-gemini-api-key

# ===========================================
# App Configuration
# ===========================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
API_BASE_URL=http://localhost:4000
EXPO_PUBLIC_API_BASE_URL=http://localhost:4000

# ===========================================
# Demo Tenant
# ===========================================
DEMO_GYM_ID=00000000-0000-0000-0000-000000000001

# ===========================================
# WhatsApp (Optional - Baileys)
# ===========================================
WHATSAPP_SESSION_PATH=./.sessions

# ===========================================
# Backend
# ===========================================
BACKEND_PORT=4000
