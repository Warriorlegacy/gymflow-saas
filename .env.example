NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret
BACKEND_PORT=4000

# AI Configuration (Free providers - get free keys at https://console.groq.com and https://aistudio.google.com)
GROQ_API_KEY=your-groq-api-key
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.3-70b-versatile
GEMINI_API_KEY=your-gemini-api-key

# WhatsApp (Baileys - free, session-based)
WHATSAPP_SESSION_PATH=./.sessions

# API URLs
API_BASE_URL=http://localhost:4000
EXPO_PUBLIC_API_BASE_URL=http://localhost:4000

# Demo tenant
DEMO_GYM_ID=00000000-0000-0000-0000-000000000001

# Razorpay (optional - free to set up, 2% per transaction)
RAZORPAY_KEY_ID=your-razorpay-key-id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret
