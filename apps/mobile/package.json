{
  "name": "@gymflow/mobile",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=20.0.0"
  },
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "build": "expo export",
    "build:android": "npx expo run:android --variant release",
    "build:ios": "npx expo run:ios --configuration Release",
    "eas:build": "eas build",
    "eas:build:dev": "eas build --profile development",
    "eas:build:prod": "eas build --profile production",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "format": "prettier --check app src"
  },
  "dependencies": {
    "@babel/runtime": "^7.27.0",
    "@expo/metro-runtime": "~4.0.1",
    "@gymflow/lib": "workspace:*",
    "@gymflow/services": "workspace:*",
    "expo": "~52.0.38",
    "expo-asset": "~11.0.5",
    "expo-constants": "~17.0.8",
    "expo-linking": "~7.0.5",
    "expo-router": "~4.0.17",
    "expo-status-bar": "~2.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-native": "0.76.9",
    "react-native-safe-area-context": "4.12.0",
    "react-native-screens": "~4.4.0",
    "react-native-web": "~0.19.13"
  },
  "devDependencies": {
    "@types/react": "^18.3.18",
    "eas-cli": "~15.0.15",
    "typescript": "^5.8.2"
  }
}
